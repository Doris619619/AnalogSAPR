# C++ / CMake build artifacts
build/
build-cmake/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
CTestTestfile.cmake
Makefile
*.exe
*.o
*.obj
*.a
*.lib

# 根目录默认/历史运行产物
/output/
