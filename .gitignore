# 各 case：只保留 input/ 与 case 级 .gitignore，其余运行产物全部忽略
cases/**
!cases/*/
!cases/*/.gitignore
!cases/*/input/
!cases/*/input/**

# Python 缓存
tools/__pycache__/
**/__pycache__/
*.pyc

# IDE and local files
.idea/
.vscode/
*.code-workspace
*.user
